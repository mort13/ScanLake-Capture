{
  "manifest_version": 3,
  "name": "ScanLake Hotkeys",
  "version": "1.0.0",
  "description": "Global hotkeys for ScanLake Capture — trigger OCR capture, save, and new cluster while in-game.",
  "permissions": [],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://capture.scanlake.rocks/*",
        "*://localhost/*",
        "*://127.0.0.1/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "capture": {
      "description": "Capture OCR scan",
      "global": true
    },
    "save-scan": {
      "description": "Save current scan",
      "global": true
    },
    "new-cluster": {
      "description": "Start a new cluster",
      "global": true
    }
  }
}
